<div id="page-loader" aria-hidden="true">
	<div class="loader-spinner"></div>
</div>

<style is:global>
/* 隱藏 OverlayScrollbars 自訂滾動條 */
body.is-loading .os-scrollbar {
	visibility: hidden !important;
}

/* ===== Page Loader ===== */
#page-loader {
	position: fixed;
	inset: 0;
	z-index: 99999;
	background: var(--page-bg, #f4f4f4);
	display: flex;
	align-items: center;
	justify-content: center;
	transition: opacity 0.5s ease, visibility 0.5s ease;
}
#page-loader.done {
	opacity: 0;
	visibility: hidden;
	pointer-events: none;
}

.loader-spinner {
	width: 36px;
	height: 36px;
	border-radius: 50%;
	border: 3.5px solid oklch(0.82 0.06 var(--hue, 260));
	border-top-color: oklch(0.55 0.20 var(--hue, 260));
	animation: spinner-rotate 0.8s linear infinite;
}

html.dark .loader-spinner {
	border-color: oklch(0.35 0.08 var(--hue, 260));
	border-top-color: oklch(0.72 0.18 var(--hue, 260));
}

@keyframes spinner-rotate {
	to { transform: rotate(360deg); }
}
</style>
