{
  "name": "fuwari",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "cross-env CHOKIDAR_USEPOLLING=1 astro dev --force",
    "start": "cross-env CHOKIDAR_USEPOLLING=1 astro dev --force",
    "check": "astro check",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "tsc --noEmit --isolatedDeclarations",
    "new-post": "node scripts/new-post.js",
    "new-post-mdx": "node scripts/new-post-mdx.js",
    "format": "biome format --write ./src && prettier --write \"src/**/*.{mdx,md,css}\"",
    "lint": "biome check --write ./src",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.6",
