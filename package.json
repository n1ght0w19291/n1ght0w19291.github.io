    "remark-github-admonitions-to-directives": "^1.0.5",
    "remark-math": "^6.0.0",
    "remark-sectionize": "^2.1.0",
    "satori": "^0.18.4",
    "sharp": "^0.34.5",
    "stylus": "^0.64.0",
    "svelte": "^5.55.7",
    "tailwindcss": "^3.4.19",
