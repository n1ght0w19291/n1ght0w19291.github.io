    "@resvg/resvg-js": "^2.6.2",
    "@swup/astro": "^1.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "6.3.0",
    "astro-expressive-code": "^0.41.7",
    "astro-icon": "^1.1.5",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.2.1",
    "hastscript": "^9.0.1",
    "katex": "^0.16.47",
    "mdast-util-to-string": "^4.0.0",
    "overlayscrollbars": "^2.16.0",
    "pagefind": "^1.5.2",
    "photoswipe": "^5.4.4",
